# ─────────────────────────────────────────────────────────────
#  Copy this file to .env.local and fill in the values.
#  NEVER commit .env.local to git.
# ─────────────────────────────────────────────────────────────

# ── Sanity CMS ────────────────────────────────────────────────
# Create a free project at https://sanity.io
NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production

# ── NextAuth ──────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# Admin login (used for credentials provider)
ADMIN_EMAIL=admin@ardentrealty.com
ADMIN_PASSWORD=change_this_password

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Resend (email) ────────────────────────────────────────────
# Get a free API key at https://resend.com
RESEND_API_KEY=re_your_api_key_here
CONTACT_EMAIL=hello@ardentrealty.com

# ── Site ──────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_NAME=ARDENT
NEXT_PUBLIC_SITE_URL=https://ardentrealty.com
